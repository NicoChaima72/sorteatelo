# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/libros-iselk"

# Next Auth
# You can generate a new secret on the command line with:
# openssl rand -base64 32
# https://next-auth.js.org/configuration/options#secret
# NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Next Auth Google Provider
# Redirect URI (dev): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Operadores de plataforma (F05/D4): CSV de emails con acceso a TODAS las Tiendas
# (rol de plataforma). OPCIONAL y fail-closed: ausente/vacío ⇒ nadie es Operador.
# La autorización normal del panel es la membresía User↔Tenant (se otorga con
# `npm run otorgar:membresia <email> <slug-tienda>`); esto es solo para el freelancer
# que opera la plataforma. Reemplaza a la ADMIN_ALLOWLIST mono-usuario pre-pivote.
# PLATFORM_OPERATOR_EMAILS="operador@ejemplo.cl"

# Cifrado de las credenciales Flow por tenant (BYO-Flow, ADR-0006). Clave AES-256
# en base64 (32 bytes). Generá la tuya con:  openssl rand -base64 32
# La de abajo es un PLACEHOLDER de ejemplo (no usar en real): reemplazala en tu .env.
CREDENTIALS_ENCRYPTION_KEY="ejemplo-reemplazar-por-openssl-rand-base64-32-x="

# Dominio raíz de la plataforma (ADR-0007): distingue el apex (zona plataforma)
# de un subdominio de Tienda. En dev se puede omitir: cae a `localhost` y las
# tiendas resuelven en `<slug>.localhost:3000` (S1). En PRODUCCIÓN es obligatoria
# (fail-fast si falta). Pública a propósito (la lee el middleware edge; no es
# secreto). La decisión abierta #4 (qué dominio) sigue abierta.
# NEXT_PUBLIC_PLATFORM_DOMAIN=""

# Flow (pasarela de pago, BYO-Flow ADR-0006): NO hay credenciales globales de
# plataforma — cada Tienda usa su propia cuenta de Flow, cifrada en la DB
# (FlowCredential). Las credenciales se obtienen en el panel de Flow
# (sandbox: https://sandbox.flow.cl). El webhook confirma server-side
# (ADR-0001), nunca el redirect del navegador.
#
# Credenciales sandbox de los tenants SEED (solo las consume `npm run
# seed:tenants`, que las cifra antes de persistir — jamás quedan en claro en la
# DB). La prueba de fuego de F01 (D1) exige DOS cuentas Flow sandbox DISTINTAS,
# una por tenant. Sin estas vars el seed siembra placeholders (no sirven para el
# E2E contra Flow).
FLOW_AUTORA_API_KEY=""
FLOW_AUTORA_SECRET_KEY=""
FLOW_PRUEBA_API_KEY=""
FLOW_PRUEBA_SECRET_KEY=""

# URL pública del webhook de confirmación (Flow la llama server-side; endpoint
# ÚNICO de plataforma — el ruteo por tenant lo hace el token). En dev necesita
# un túnel público (p.ej. ngrok) apuntando a /api/webhooks/flow.
FLOW_URL_CONFIRMATION="https://<tu-tunel-publico>/api/webhooks/flow"
# URL de retorno del navegador tras el checkout de Flow (página dev throwaway).
FLOW_URL_RETURN="http://localhost:3000/dev/checkout/retorno"

# Storage de PDFs — Cloudflare R2 (ADR-0002/0009, F03). Bucket PRIVADO S3-compatible
# con paths per-tenant; el PDF nunca se sirve por enlace público, solo por URL
# prefirmada efímera (~10 min) autorizada por un DownloadGrant. A diferencia de Flow
# (BYO por tenant), el storage es de PLATAFORMA: una cuenta R2 del Operador, un bucket.
# Se obtienen en el dashboard de Cloudflare R2 (crear bucket + API token con permiso
# "Object Read & Write" scopeado a ese bucket). OPCIONALES: la app arranca sin ellas;
# la factory hace fail-fast al presignar/subir. Las claves son SECRETAS (jamás en logs).
#   - R2_ENDPOINT = https://<account-id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""

# Correo transaccional — Resend (ADR-0010, F04). Cuenta de PLATAFORMA (una sola, del
# Operador; NO BYO por tenant). La API key se obtiene en https://resend.com (API Keys).
# OPCIONAL: la app arranca sin ella; la factory hace fail-fast al enviar si falta. Es
# SECRETA: jamás en logs ni en el repo. En el MVP se envía desde el remitente de prueba
# `onboarding@resend.dev` (sin dominio verificado) hasta cerrar la decisión abierta #4
# (dominio de la plataforma) — al cerrarla solo cambia el remitente `from`, no esta var.
RESEND_API_KEY=""

# URL pública de la app para los enlaces de descarga del correo (D8). El endpoint
# `/api/descargas/<token>` es de PLATAFORMA (token global, sin subdominio). OPCIONAL: si
# se omite, el correo cae a NEXTAUTH_URL. Útil si el dev server vive en otro puerto (:3001)
# o para desacoplar el correo del auth. Sin barra final.
# APP_URL="http://localhost:3000"
