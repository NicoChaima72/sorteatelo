// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  @@index([name])
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String             @id @default(cuid())
  name          String?
  email         String?            @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  memberships   TenantMembership[] // Tiendas que este Organizador administra (F05, S6)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Dominio libros-iselk — SaaS multi-tenant (F01, ADR-0005/0006).
// Aprobado por schema-guardian (aplicado con db push, sin migraciones — S7/I8).
//
// Reglas de oro:
// - Multi-tenancy (ADR-0005): todo modelo del dominio comercial (Product/Order/
//   OrderItem/Payment) lleva `tenantId` + FK a Tenant + `@@index([tenantId, …])`;
//   toda query de dominio se filtra por el tenant resuelto SERVER-SIDE, nunca por
//   input del cliente. `Tenant` y `FlowCredential` son entidades de PLATAFORMA
//   (fuera del scoping por tenantId). Uniques de negocio compuestos con tenantId
//   cuando el valor puede reaparecer en otro tenant (aquí no hay slugs de producto).
// - Dinero en Decimal(15,2) nunca Float; onDelete explícito; @@index en FKs queriables.
// - Restrict hacia padres auditables (Tenant/Order/Product/Payment) — un Tenant no
//   se borra, se SUSPENDE (S9). Cascade solo para composición intrínseca del agregado
//   (OrderItem→Order; FlowCredential→Tenant).
// - BYO-Flow (ADR-0006): FlowCredential 1-1 con Tenant, apiKey/secretKey CIFRADAS
//   at-rest (AES-256-GCM), flag sandbox por tenant; secretos jamás en texto plano.
// ─────────────────────────────────────────────────────────────────────────────

enum TenantStatus {
  ALTA
  CONFIGURACION
  PUBLICADA
  SUSPENDIDA
}

enum OrderStatus {
  PENDIENTE
  PAGADO
  FALLIDO
}

enum PaymentStatus {
  PENDIENTE
  PAGADO
  FALLIDO
}

// Una Tienda: la unidad de aislamiento del SaaS (ADR-0005). Vive en su subdominio
// (slug, ADR-0007). Entidad de plataforma — NO lleva tenantId. Ver CONTEXT.md § Tienda.
model Tenant {
  id            String       @id @default(cuid())
  slug          String       @unique // subdominio, único a nivel plataforma (S3); inmutable tras publicar
  nombre        String
  estado        TenantStatus @default(ALTA) // ciclo de vida (S9): solo PUBLICADA resuelve storefront
  // Config básica de plantilla (F05/D8, S4): el Organizador la carga en el panel;
  // el theming real del storefront sobre estos valores lo hace F06 (solo persiste acá).
  descripcion   String? // texto breve de la tienda (marketing)
  logoUrl       String? // ref al logo (F06 define su storage/tratamiento real)
  colorPrimario String? // color de marca del tenant (hex/HSL; F06 lo aplica al tema)
  // ── Textos del storefront (F06/D4, schema-guardian APPROVE). El Organizador los edita en el
  // panel (guardarConfiguracionTienda); el render del hero/aviso los consume con fallback. NO
  // queriables (se leen por el tenant ya resuelto por id/slug) ⇒ sin @@index.
  // OJO: `avisoTexto` es un banner promocional OPCIONAL — NO es el Disclaimer del sorteo
  // (ADR-0008/D7), que es obligatorio, fijo de plataforma y se muestra siempre con sorteo activo.
  heroTitulo    String? // título del hero del storefront; fallback a `nombre`
  heroSubtitulo String? // subtítulo del hero; fallback a `descripcion`
  heroImageUrl  String? // URL PÚBLICA (bucket R2 público, ADR-0013) de la imagen del hero, con cache-buster ?v= (plantilla-rica F02/D2); null ⇒ gradiente temático (degradación elegante D7). No queriable ⇒ sin @@index
  avisoTexto    String? // banner de aviso opcional; null = no se muestra
  // ── Redes y contacto público del footer (plantilla-rica F02/D2, ADR-0013). Editables por el
  // Organizador en Configuración (guardarConfiguracionTienda); el footer las consume con degradación
  // elegante (D7: red faltante ⇒ se oculta el ícono). No queriables (se leen por el tenant ya
  // resuelto) ⇒ sin @@index.
  instagramUrl  String? // URL del perfil de Instagram; null = ícono oculto
  tiktokUrl     String? // URL del perfil de TikTok; null = ícono oculto
  whatsappUrl   String? // enlace de WhatsApp; null = ícono oculto
  contactoEmail String? // email de contacto PÚBLICO del Organizador (footer). Distinto de Order.email (identidad del comprador, ADR-0004)
  // Bases del sorteo como TEXTO borrador del Organizador (F05/D8, ADR-0008). Distinto de
  // `Raffle.basesUrl` (F02), que es el enlace al ARCHIVO de bases (lo sube F03). Coexisten a
  // propósito: acá vive el borrador editable a nivel Tienda; el archivo final vive en el Sorteo.
  basesSorteo   String?
  // ── Aceptación de los Términos de Servicio (F08/D2, ADR-0008). Los 3 se escriben JUNTOS en
  // aceptarTos. Espejan el patrón de auditoría de Raffle (ejecutadoAt/ejecutadoPor), con una
  // diferencia: acá es write-MANY (se sobrescriben al re-aceptar una versión nueva del ToS) — el
  // historial legal completo se difiere a un modelo TosAcceptance en F10. El gate de publicación
  // exige tosVersion === TOS_VERSION vigente. No queriables (se leen por el tenant ya resuelto) ⇒ sin @@index.
  tosVersion     String?   // versión del ToS aceptada (ej. "2026-07-17"); null = nunca aceptó
  tosAceptadoAt  DateTime? // timestamp de la última aceptación; null hasta aceptar
  tosAceptadoPor String?   // snapshot del EMAIL del aceptante (durable si el User se borra, ADR-0004)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  flowCredential FlowCredential?
  products       Product[]
  orders         Order[]
  orderItems     OrderItem[]
  payments       Payment[]
  raffles        Raffle[] // efectos post-pago F02
  raffleEntries  RaffleEntry[] // efectos post-pago F02
  downloadGrants DownloadGrant[] // efectos post-pago F02
  memberships    TenantMembership[] // Organizadores que administran esta Tienda (F05, S6)
  storefrontPages StorefrontPage[] // Página(s) de tienda del page builder (ADR-0016)
  storefrontPageVersions StorefrontPageVersion[] // Snapshots de publicación (F12, ADR-0016)
  pageAssets      PageAsset[] // imágenes libres del editor de la Página (catálogo-v2 F08, ADR-0013/0016)
}

// Credenciales Flow propias del Organizador (BYO-Flow, ADR-0006). 1-1 con Tenant.
// apiKey/secretKey CIFRADAS at-rest (I5) — nunca texto plano en DB, logs ni respuestas.
// Composición intrínseca del agregado Tenant ⇒ Cascade. Ver CONTEXT.md § CredencialFlow.
model FlowCredential {
  id               String   @id @default(cuid())
  tenantId         String   @unique // 1-1 con Tenant (el @unique ya crea el índice)
  apiKeyCifrada    String // apiKey de Flow cifrada (AES-256-GCM, iv+tag+ct empaquetados)
  secretKeyCifrada String // secretKey de Flow cifrada (mismo formato)
  sandbox          Boolean  @default(true) // sandbox vs producción, por tenant
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Membresía Organizador↔Tienda (F05, S6): liga un User (cuenta de plataforma, frontera
// NextAuth) a un Tenant que administra. MVP: un Organizador dueño por Tienda, SIN campo
// rol (roles finos post-MVP). Entidad de PLATAFORMA/acceso (como los modelos NextAuth):
// su tenantId es FK real, no una columna de scoping de dominio. La AUTORIZACIÓN del panel
// sale de acá (o del flag Operador por env), nunca del input (I1, lección H1 de datawalt-app).
// Ver CONTEXT.md § Organizador.
model TenantMembership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([userId, tenantId]) // 1 membresía por (usuario, tienda); prefijo cubre lookups por userId (sesión→tiendas)
  @@index([tenantId]) // dirección inversa: organizadores de una tienda (panel Operador)
}

// Un producto digital descargable (MVP: PDF) que una Tienda vende. Ver CONTEXT.md § Producto.
// (rename de Book — D3/S5). Pertenece a exactamente una Tienda (tenantId).
model Product {
  id             String          @id @default(cuid())
  tenantId       String
  titulo         String
  descripcion    String
  precio         Decimal         @db.Decimal(15, 2) // precio final al público, IVA incluido (I4)
  portadaUrl     String?
  pdfPath        String? // null = PDF pendiente; NO-null = key determinística `<tenantId>/<productId>.pdf` verificada en R2 privado (ADR-0002/0009), la escribe SOLO confirmarPdfProducto tras headObject; nunca enlace público
  activo         Boolean         @default(true)
  participaEnSorteo Boolean      @default(false) // opt-in al Sorteo (ADR-0012/D1): comprarlo genera Tickets en el Raffle ACTIVO del tenant. Se snapshotea en OrderItem al comprar. No queriable por sí solo (se lee por el Product ya scopeado) ⇒ sin @@index
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  orderItems     OrderItem[]
  downloadGrants DownloadGrant[] // efectos post-pago F02

  @@index([tenantId, activo]) // el catálogo consulta WHERE tenantId = ? AND activo = true; sirve tenant-only por prefijo
}

// Una compra dentro de una Tienda. Identidad del comprador = su correo (ADR-0004). Ver CONTEXT.md § Orden.
model Order {
  id             String          @id @default(cuid())
  tenantId       String
  email          String // identidad del comprador (ADR-0004)
  estado         OrderStatus     @default(PENDIENTE)
  total          Decimal         @db.Decimal(15, 2) // suma de precios de ítems (I4)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  items          OrderItem[]
  payment        Payment?
  downloadGrants DownloadGrant[] // efectos post-pago F02
  raffleEntries  RaffleEntry[] // efectos post-pago F02

  @@index([tenantId, email]) // búsquedas siempre tenant-scoped; sirve tenant-only por prefijo
  @@index([tenantId, estado])
}

// Línea de una Orden. Snapshot inmutable al comprar (sin updatedAt): precio UNITARIO congelado (I4),
// más `cantidad` y `participaEnSorteo` congelados (ADR-0012/D2/D5). Subtotal = precio × cantidad en Decimal server-side.
model OrderItem {
  id                String   @id @default(cuid())
  tenantId          String
  orderId           String
  productId         String
  precio            Decimal  @db.Decimal(15, 2) // snapshot del precio UNITARIO del Product al comprar (I4)
  cantidad          Int      @default(1) // unidades de esta línea (≥1 vía Zod; default 1 = ítems históricos, implícitamente 1u)
  participaEnSorteo Boolean  @default(false) // SNAPSHOT del flag del Product al comprar (D2): mantiene K de tickets estable ante replay del webhook aunque el Organizador togglee el flag vivo
  createdAt         DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId]) // 1 línea por producto por orden (orderId ya es tenant-bound); prefijo cubre el índice de orderId
  @@index([tenantId])
  @@index([productId])
}

// El cobro vía Flow sobre una Orden, con las credenciales de SU Tenant (ADR-0006).
// Confirmación server-side; webhook idempotente que rutea por tenant (ADR-0001). Ver CONTEXT.md § Pago.
model Payment {
  id        String        @id @default(cuid())
  tenantId  String
  orderId   String        @unique
  token     String?       @unique // token de Flow (payment/create); global (el ruteo del webhook resuelve token⇒Payment⇒tenant); null hasta obtenerlo
  flowOrder Int? // nº de orden interno de Flow (getStatus)
  estado    PaymentStatus @default(PENDIENTE)
  monto     Decimal       @db.Decimal(15, 2) // monto cobrado (= Order.total en F01)
  fee       Decimal?      @db.Decimal(15, 2) // comisión CRUDA que devuelve Flow en getStatus (I4)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Efectos post-pago per-tenant (F02, ADR-0002/0005). Aprobado por schema-guardian
// (APPROVE; aplicado con db push aditivo). Los tres modelos llevan `tenantId` +
// FK Restrict a Tenant (una Tienda se SUSPENDE, no se borra — S9). Se materializan
// dentro de la MISMA $transaction que la transición PENDIENTE→PAGADO del webhook,
// idempotentes por sus @@unique (I2). Uniques de idempotencia SIN tenantId redundante
// (orderId/raffleId ya son tenant-bound — mismo criterio que OrderItem).
// ─────────────────────────────────────────────────────────────────────────────

enum RaffleStatus {
  ACTIVO
  CERRADO
}

// El sorteo promocional de una Tienda (CONTEXT § Sorteo). Per-tenant (ADR-0005).
// A lo sumo un Raffle ACTIVO por tenant (S5): invariante de sembrado/gestión (F05),
// NO constraint de DB (Prisma no expresa unique parciales). El use case lo lee con
// `findFirst` scoped al tenantId de la orden. Ver CONTEXT.md § Sorteo.
model Raffle {
  id           String       @id @default(cuid())
  tenantId     String
  nombre       String
  premio       String
  estado       RaffleStatus @default(ACTIVO)
  fechaInicio  DateTime
  fechaFin     DateTime
  basesUrl       String? // bases del sorteo (del Organizador, ADR-0008); carga real en F05
  premioImageUrl String? // URL PÚBLICA (bucket R2 público, ADR-0013) de la imagen del premio, con cache-buster ?v= (plantilla-rica F02/D5); null ⇒ gradiente temático (D7). No queriable ⇒ sin @@index
  // ── Ejecución auditable del sorteo (F05, aditivo sobre el modelo de F02). ──────────
  // Los tres campos se escriben JUNTOS, UNA sola vez, en el use case que ejecuta el
  // sorteo (transición ACTIVO→CERRADO). `ejecutadoAt` es la llave de idempotencia:
  // null = no ejecutado; el guard es `WHERE ejecutadoAt IS NULL` — invariante de use
  // case, NO constraint de DB (mismo criterio que "1 Raffle ACTIVO por tenant", S5).
  ganadorEmail String? // snapshot del correo del ganador (identidad = correo, ADR-0004); denormalizado, sin 2ª FK a RaffleEntry
  ejecutadoAt  DateTime? // timestamp de ejecución; null hasta ejecutar (llave de idempotencia)
  ejecutadoPor String? // snapshot del EMAIL del ejecutor (auditoría de "quién"; durable si el User se borra, ADR-0004)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  entries RaffleEntry[]

  @@index([tenantId, estado]) // lookup del ACTIVO de ESA tienda
}

// Participación (CONTEXT § Participación): una fila por TICKET (ADR-0012), no una por orden.
// Se crean K filas con ordinal 0..K-1 en el Raffle ACTIVO del tenant de la orden. Inmutable (sin updatedAt).
model RaffleEntry {
  id        String   @id @default(cuid())
  tenantId  String
  raffleId  String
  orderId   String
  email     String // snapshot de Order.email al crear la entry (I5)
  ordinal   Int      @default(0) // discriminador 0..K-1 del ticket dentro de la orden (D3); default 0 satisface el unique ampliado en entries históricas (cada (raffle,orden) tenía ≤1)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Restrict)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([raffleId, orderId, ordinal]) // idempotencia por-ticket: K filas 0..K-1 vía createMany(skipDuplicates); prefijo [raffleId, orderId] cubre lookups por raffle y por (raffle, orden)
  @@index([tenantId])
  @@index([orderId])
}

// Entitlement (CONTEXT § Entitlement, ADR-0002): autoridad de descarga por (Orden
// pagada, Producto). Inmutable (sin updatedAt). El `token` opaco crypto-random es la
// autoridad intrínseca; la URL firmada corta de R2 la genera F03. Ver CONTEXT.md § Entitlement.
model DownloadGrant {
  id        String   @id @default(cuid())
  tenantId  String
  orderId   String
  productId String
  token     String   @unique // opaco crypto-random; global como Payment.token (F03 rutea token⇒grant⇒tenant)
  expiresAt DateTime // ventana de validez del derecho (S3: 30 días; política final en F03)
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId]) // idempotencia: un grant por (orden, producto); orderId ya es tenant-bound
  @@index([tenantId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Page builder (carril A, ADR-0016/0017/0018). Aprobado por schema-guardian
// (APPROVE con onDelete: Cascade; aplicado con db push ADITIVO — tabla nueva).
// ─────────────────────────────────────────────────────────────────────────────

// Página de tienda como Documento JSON (ADR-0016). Una fila por (tenantId, slug='home').
// El storefront público lee SOLO publishedJson (ADR-0016/I5); el Borrador (draftJson) lo escriben
// el MCP/use cases y se copia a published al Publicar (acción humana explícita, I6). `version` =
// lock optimista del borrador (mutaciones con expectedVersion, I10). tenantId columna real (FK +
// índice vía prefijo del unique), jamás dentro del JSON (ADR-0005/I1). Referencias-no-copias: el
// JSON no persiste precios ni datos del dominio (ADR-0017/I2). Ver CONTEXT.md § Página de la tienda.
//
// onDelete: Cascade — config del storefront, composición intrínseca del agregado Tenant SIN vida
// propia (mismo criterio que FlowCredential). No es registro de plata ni auditable ⇒ NO aplica el
// Restrict del dominio comercial; regenerable desde las columnas de Tenant (documentoInicial).
model StorefrontPage {
  id            String    @id @default(cuid())
  tenantId      String
  slug          String    @default("home") // ruta de la página dentro de la Tienda; 'home' = raíz
  draftJson     Json // Documento de Página en edición (validado por PageDocumentSchema al escribir); nunca null (lo siembra documentoInicial)
  publishedJson Json? // último Documento publicado; null hasta la 1ª publicación
  version       Int       @default(1) // lock optimista del borrador (expectedVersion)
  publishedAt   DateTime? // timestamp de la última publicación; null hasta publicar
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug]) // una página por (Tienda, ruta); el prefijo [tenantId] cubre lookups tenant-scoped
}

// Snapshot APPEND-ONLY del Documento publicado, uno por cada Publicar (ADR-0016 §Consecuencias, F12).
// Historial + rollback: "copiá una revisión vieja al draft y republicá". `publicarPagina` SOLO appendea
// (nunca update/delete) dentro de su $transaction (I10). onDelete: Cascade — historia de config del
// storefront subordinada a StorefrontPage (mismo criterio Cascade que StorefrontPage y FlowCredential);
// NO es registro de plata: el blindaje real lo dan los FK Restrict de Order/Payment/Product, que ya
// hacen indeleble a un tenant comercial. Sin FK directa a StorefrontPage: la historia se ancla al par
// (tenantId, slug) para sobrevivir a una eventual recreación de la fila StorefrontPage. Inmutable ⇒ sin
// updatedAt. Ver CONTEXT.md § Publicar.
model StorefrontPageVersion {
  id          String   @id @default(cuid())
  tenantId    String
  slug        String   @default("home") // qué página (espeja StorefrontPage.slug)
  revision    Int // ordinal MONOTÓNICO por (tenantId, slug): la N-ésima publicación; COALESCE(max,0)+1 en la $transaction de publicarPagina. Handle estable para UI ("v3") y rollback
  documento   Json // snapshot del Documento publicado en ese instante (== StorefrontPage.publishedJson al publicar; ya schema-válido)
  publishedBy String? // snapshot del email/label del que publicó (auditoría durable si el User se borra, ADR-0004; MVP: "operador" vía MCP)
  createdAt   DateTime @default(now()) // instante del Publicar (ES el publishedAt: la fila se inserta AL publicar)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug, revision]) // garantiza la monotonía del ordinal + lista/ordena el historial; el prefijo cubre lookups por página/tenant y sirve ORDER BY revision DESC por index scan
}

// Imagen libre subida por el Organizador vía el editor de la Página (catálogo-v2 F08, ADR-0016).
// Metadata de un objeto del bucket R2 PÚBLICO (ADR-0013), namespace <tenantId>/pagina/<id> — la key
// la deriva SIEMPRE server-side (`keyPaginaAsset`, storagePublico.ts); el cliente jamás la elige (I6),
// por eso NO se persiste (evita 2ª fuente de verdad — se recomputa de id+tenantId). onDelete: Cascade:
// config del storefront sin vida propia (mismo criterio que StorefrontPage/StorefrontPageVersion), NO
// registro de plata ⇒ NO aplica el Restrict del dominio comercial. Inmutable ⇒ sin updatedAt. Borrar la
// fila NO borra el objeto R2 (GC de huérfanos fuera de alcance, D11) ni invalida documentos (URL rota ⇒
// degradación elegante vía <ImagenConFallback>).
model PageAsset {
  id          String   @id @default(cuid())
  tenantId    String
  contentType String // de la allowlist CONTENT_TYPES_IMAGEN (png/jpeg/webp)
  bytes       Int // tamaño del objeto, para el límite de peso + la cuota por tenant (Int, NO dinero)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

